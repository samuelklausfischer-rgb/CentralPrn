# Credenciais da API Omie (NÃO commitar valores reais — use .env.local)
# Obtidas em: Omie → Configurações → Geral → App Key/App Secret

# Empresa PRN
VITE_APP_KEY_OMIE=your_app_key_here
VITE_APP_SECRET_OMIE=your_app_secret_here

# Empresa MedImagem
VITE_APP_KEY_OMIE_MEDIMAGEM=your_medimagem_app_key_here
VITE_APP_SECRET_OMIE_MEDIMAGEM=your_medimagem_app_secret_here

# Supabase (projeto supabase_financeiro) — histórico de snapshots do dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_key_here
